# ── WalletConnect / RainbowKit ────────────────────────────────────
# Free project ID from https://cloud.reown.com (formerly walletconnect)
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# ── Default chain ────────────────────────────────────────────────
# 42161  = Arbitrum One
# 421614 = Arbitrum Sepolia
NEXT_PUBLIC_DEFAULT_CHAIN_ID=42161

# Optional explicit RPC endpoints for frontend reads (recommended in production)
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Deployed contracts — Arbitrum One ────────────────────────────
# Fill in after running forge script/Deploy.s.sol
NEXT_PUBLIC_VAULT_ARB_ONE=
NEXT_PUBLIC_VAULT_LENS_ARB_ONE=
NEXT_PUBLIC_HOOK_ARB_ONE=
NEXT_PUBLIC_DISTRIBUTOR_ARB_ONE=
NEXT_PUBLIC_BOOTSTRAP_ARB_ONE=0x3E6Ed05c1140612310DDE0d0DDaAcCA6e0d7a03d

# Underlying asset (defaults to native USDC on Arbitrum)
NEXT_PUBLIC_ASSET_ARB_ONE=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
NEXT_PUBLIC_ASSET_SYMBOL=USDC
NEXT_PUBLIC_ASSET_DECIMALS=6
NEXT_PUBLIC_PAIR_SYMBOL=WETH / USDC

# ── Deployed contracts — Arbitrum Sepolia (optional testnet) ─────
NEXT_PUBLIC_VAULT_ARB_SEPOLIA=
NEXT_PUBLIC_HOOK_ARB_SEPOLIA=
NEXT_PUBLIC_DISTRIBUTOR_ARB_SEPOLIA=
NEXT_PUBLIC_BOOTSTRAP_ARB_SEPOLIA=
NEXT_PUBLIC_ASSET_ARB_SEPOLIA=
