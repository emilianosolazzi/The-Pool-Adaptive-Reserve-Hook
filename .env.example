# ─────────────────────────────────────────────────────────────────
#  DeFi Hook Protocol — Environment Variables
#  cp .env.example .env  →  fill in values  →  NEVER commit .env
# ─────────────────────────────────────────────────────────────────

# ── Deployer ──────────────────────────────────────────────────────
# Private key of the wallet broadcasting deploy transactions.
# Fund it with ~0.05 ETH on the target network for gas.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC ───────────────────────────────────────────────────────────
# Arbitrum Sepolia testnet (free ETH: https://faucet.quicknode.com/arbitrum/sepolia)
ARBITRUM_TESTNET_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Arbitrum One mainnet (uncomment when ready)
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ── Uniswap v4 — Arbitrum Sepolia (chain 421614) ─────────────────
# Source: https://docs.uniswap.org/contracts/v4/deployments
POOL_MANAGER=0xFB3e0C6F74eB1a21CC1Da29aeC80D2Dfe6C9a317
POS_MANAGER=0xAc631556d3d4019C95769033B5E719dD77124BAc

# Uniswap v4 — Arbitrum One mainnet (uncomment when ready)
# POOL_MANAGER=0x360e68faccca8ca495c1b759fd9eee466db9fb32
# POS_MANAGER=0xd88f38f930b7952f2db2432cb002e7abbf3dd869

# ── Pool Tokens ───────────────────────────────────────────────────
# TOKEN0 must sort lower than TOKEN1 (Uniswap v4: currency0 < currency1).
# For testnet: deploy two MockERC20 tokens (see README quickstart),
# or use any existing Arbitrum Sepolia ERC-20 pair you own.
# The vault deposits in TOKEN0, so pick the "stable" side as TOKEN0.
TOKEN0=0xYOUR_TOKEN0_ADDRESS
TOKEN1=0xYOUR_TOKEN1_ADDRESS

# ── Treasury ─────────────────────────────────────────────────────
# Receives 20% of hook fees + vault performance fees.
# Testnet: use your own wallet. Mainnet: use a Safe multisig.
TREASURY_ADDRESS=0xYOUR_TREASURY_ADDRESS
TREASURY=${TREASURY_ADDRESS}

# ── Optional ─────────────────────────────────────────────────────
# PERFORMANCE_FEE_BPS=500      # 5% of yield goes to treasury
# MAX_TVL=0                    # 0 = unlimited deposit ceiling
# MAX_FEE_BPS=50               # 0.5% hard cap on hook fee per swap
# POOL_FEE=3000                # fee tier: 100|500|3000|10000
# TICK_SPACING=60              # must match fee tier: 100→1 500→10 3000→60 10000→200
# SQRT_PRICE_X96=              # leave blank for 1:1 default

# ── Ownership (recommended for mainnet) ───────────────────────────
# Deploys a TimelockController (48h delay by default) and transfers
# ownership of all three contracts to it. Multisig calls acceptOwnership()
# on each contract via the timelock after the delay.
# OWNER=0xYOUR_SAFE_MULTISIG_HERE
# TIMELOCK_DELAY=172800        # seconds (default: 48h)

# ── Arbiscan verification ─────────────────────────────────────────
# Get a free key at https://arbiscan.io/myapikey
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY_HERE
ETHERSCAN_API_KEY=${ARBISCAN_API_KEY}
